// Schéma Prisma — Système de persistance MonASOCFoot
// Voir docs/specs/scaffolding-projet-monasocfoot.md et docs/specs/persistence-alwaysdata-monasocfoot.md.
// Modèle Utilisateur repris à l'identique du pattern challenge-cardegall (lib auth partagée).
// Modèles Activite/Disponibilite à enrichir lors des specs gestion-activites-admin /
// saisie-disponibilite-journee / saisie-disponibilite-activite (phases 1 et 2).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id                String          @id @default(uuid())
  providerId        String          @unique
  provider          String
  email             String
  displayName       String
  role              RoleUtilisateur @default(joueur)
  dateApparition    String
  derniereConnexion String

  @@map("utilisateur")
}

enum RoleUtilisateur {
  admin
  joueur
}

// ─── Socle minimal activite/disponibilite (lecture seule pour cette feature) ───
// Champs/contraintes d'écriture (validations métier, etc.) à compléter par
// gestion-activites-admin / saisie-disponibilite-journee / saisie-disponibilite-activite.

model Activite {
  id               String         @id @default(uuid())
  /// Nullable depuis `pour-grer-les-activits-il-faut-pouvoir-bouger-lactivit-dune-` : une
  /// activité peut être créée/exister sans date assignée (colonne « Sans date » de la
  /// planification admin), tant qu'elle n'a pas été glissée sur une date du calendrier.
  date             String?
  heureConvocation String
  heureDebut       String
  label            String
  type             TypeActivite
  commentaire      String?        @db.Text
  /// Lieu de l'activité (stade, salle…), nullable — cf. spec
  /// sur-la-page-dtail-dune-cration-dactivit-mettre-par-dfaut-heu.
  lieu             String?
  source           SourceActivite @default(manuel)
  /// Identifiant stable côté site du district — clé de dédup pour l'import automatique
  /// (cf. spec import-matchs-site-district). Null pour les activités saisies manuellement.
  idExterne        String?        @unique
  /// Équipe du club concernée (A/B/Vét), nullable — ex. une AG ou un barbecue n'en a pas.
  equipe           EquipeClub?

  disponibilitesActivite DisponibiliteActivite[]

  @@map("activite")
}

enum TypeActivite {
  match
  autre
}

enum SourceActivite {
  manuel
  import
}

enum EquipeClub {
  A
  B
  Vet
}

model DisponibiliteJournee {
  id            String              @id @default(uuid())
  utilisateurId String
  date          String
  statut        StatutDisponibilite
  commentaire   String?             @db.Text

  @@unique([utilisateurId, date])
  @@map("disponibilite_journee")
}

model DisponibiliteActivite {
  id            String              @id @default(uuid())
  utilisateurId String
  activiteId    String
  statut        StatutDisponibilite
  commentaire   String?             @db.Text

  activite Activite @relation(fields: [activiteId], references: [id])

  @@unique([utilisateurId, activiteId])
  @@map("disponibilite_activite")
}

enum StatutDisponibilite {
  present
  disponible
  absent
  autre
}
