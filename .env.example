PORT=3020
CORS_ORIGINS=http://localhost:5193

# ─── Base de données (Prisma / MySQL — local en dev, AlwaysData en staging/prod) ───
DATABASE_URL="mysql://root:password@localhost:3306/monasocfoot?ssl=false"
# Exemple AlwaysData (cf. spec persistence-alwaysdata-monasocfoot) :
# DATABASE_URL="mysql://<user>:<password>@mysql-<account>.alwaysdata.net:3306/<database>?ssl=true"

# ─── Auth (Passport.js + JWT, lib @rchcu9-dotcom/auth-passport-back) ──────────────
JWT_SECRET=<chaine-aleatoire-longue>
JWT_EXPIRES_IN=7d
# Tant que ces deux valeurs sont absentes/placeholders, GET /auth/google répond 503
# et POST /auth/dev-login (dev uniquement) permet de tester l'app sans Google.
GOOGLE_CLIENT_ID=<depuis-console.cloud.google.com>
GOOGLE_CLIENT_SECRET=<depuis-console.cloud.google.com>
GOOGLE_CALLBACK_URL=http://localhost:3020/auth/google/callback
FRONT_URL=http://localhost:5193
# Le premier utilisateur (Google ou dev-login) avec cet email devient automatiquement admin.
ADMIN_BOOTSTRAP_EMAIL=<email-du-premier-admin>
# true en local pour activer POST /auth/dev-login ; absent/false ailleurs.
ENABLE_DEV_LOGIN=true

# ─── Import automatique des matchs (cf. spec import-matchs-site-district) ─────────
# URL du site du district — reste à communiquer par Lionel (format API/HTML non confirmé).
# Tant qu'absente, POST /activites/import-district répond 503.
# DISTRICT_SOURCE_URL=
